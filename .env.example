# Copy to .env and fill in. DwarfWeave is OpenRouter-first (item 07).

# OpenRouter (primary) — one key, many models: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model slug. OpenRouter uses provider/model. Examples:
#   openai/gpt-4o, anthropic/claude-3.7-sonnet, google/gemini-2.0-flash
LLM_MODEL=openai/gpt-4o

# Optional
# LLM_BASE_URL=https://openrouter.ai/api/v1

# Direct-OpenAI fallback (used only when OPENROUTER_API_KEY is unset)
OPENAI_API_KEY=
